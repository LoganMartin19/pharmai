rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isAdmin() { return isSignedIn() && request.auth.token.admin == true; }
    function isPharmacyMember(orgId) {
      return isSignedIn()
        && orgId is string
        && exists(/databases/$(database)/documents/pharmacyOrganisations/$(orgId)/members/$(request.auth.uid))
        && get(/databases/$(database)/documents/pharmacyOrganisations/$(orgId)/members/$(request.auth.uid)).data.active == true;
    }
    function isPharmacyManager(orgId) {
      return isPharmacyMember(orgId)
        && get(/databases/$(database)/documents/pharmacyOrganisations/$(orgId)/members/$(request.auth.uid)).data.role in ["org_admin", "branch_manager"];
    }
    function isPharmacyOwner(partnerId) {
      return isSignedIn()
        && partnerId is string
        && exists(/databases/$(database)/documents/pharmacyPartners/$(partnerId))
        && get(/databases/$(database)/documents/pharmacyPartners/$(partnerId)).data.ownerUid == request.auth.uid;
    }

    // Caregiver is allowed if the patient has users/{patientUid}/careLinks/{caregiverUid}.role == "caregiver"
    function isCaregiverFor(patientUid) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(patientUid)/careLinks/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(patientUid)/careLinks/$(request.auth.uid)).data.role == "caregiver";
    }

    match /users/{uid} {
      // Patient or linked caregiver can READ the user doc
      allow read: if isOwner(uid) || isCaregiverFor(uid);
      // Only the patient can WRITE their user doc
      allow write: if isOwner(uid);

      // Reminders: patient can read/write; linked caregiver can read
      match /reminders/{rid} {
        allow read: if isOwner(uid) || isCaregiverFor(uid);
        allow write: if isOwner(uid);
      }

      // Care links & tokens managed by the owner only
      match /careLinks/{cid} {
        allow read, write: if isOwner(uid);
        allow update: if isSignedIn()
          && request.auth.uid == cid
          && isCaregiverFor(uid)
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['notifyCare', 'notifyDelayMinutes']);
      }
      match /fcmTokens/{tid} {
        allow read, write: if isOwner(uid);
      }
      match /expoPushTokens/{tid} {
        allow read, write: if isOwner(uid);
      }

      // Caregiver inbox alerts are written by Cloud Functions with Admin SDK.
      // The signed-in caregiver can listen for and mark their own alerts delivered.
      match /inbox/{alertId} {
        allow read, update, delete: if isOwner(uid);
        allow create: if false;
      }

      // 👇 NEW: pending alerts created by the PATIENT app for backend processing
      match /carePendingAlerts/{aid} {
        // App writes these when a dose notification fires and isn’t taken yet
        allow create: if isOwner(uid);

        // Keep private to the patient app (backend uses Admin SDK, bypassing rules)
        allow read: if isOwner(uid);

        // Allow the patient app to clean up its own alerts if you add UI to dismiss
        allow update, delete: if isOwner(uid);
      }

      match /chats/{chatId} {
        allow read: if isOwner(uid);
        allow write: if false;

        match /messages/{messageId} {
          allow read: if isOwner(uid);
          allow write: if false;
        }
      }
    }

    // Care invites: any signed-in user can create/consume; no public reads
    match /careInvites/{inviteId} {
      allow create, update, delete: if isSignedIn();
      allow read: if false;
    }

    // Public active partner metadata used only to label/rank sponsored pharmacy results.
    match /pharmacyPartners/{partnerId} {
      allow read: if isSignedIn()
        && (resource.data.active == true || resource.data.ownerUid == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // Multi-tenant pharmacy portal. Membership documents are provisioned by PharmAI admins.
    match /pharmacyOrganisations/{orgId} {
      allow read: if isAdmin() || isPharmacyMember(orgId);
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isPharmacyManager(orgId)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["contact", "serviceConfiguration", "updatedAt"]));

      match /members/{memberUid} {
        allow read: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid) || isPharmacyMember(orgId);
        allow write: if isAdmin();
      }
      match /branches/{branchId} {
        allow read: if isAdmin() || isPharmacyMember(orgId);
        allow write: if isAdmin() || isPharmacyManager(orgId);
      }
    }

    // Required for the portal's collectionGroup("members") lookup. The query
    // must constrain uid to the signed-in user and active to true.
    match /{path=**}/members/{memberUid} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.uid == request.auth.uid && resource.data.active == true);
      allow write: if false;
    }

    // User-created refill requests plus pharmacy-owner status updates.
    match /pharmacyRequests/{requestId} {
      allow create: if isSignedIn()
        && request.resource.data.userUid == request.auth.uid
        && request.resource.data.status == "pending";
      allow read: if isSignedIn()
        && (
          resource.data.userUid == request.auth.uid
          || isPharmacyOwner(resource.data.pharmacyPartnerId)
          || isPharmacyMember(resource.data.pharmacyOrgId)
          || isAdmin()
        );
      allow update: if isSignedIn()
        && resource.data.userUid == request.auth.uid
        && request.resource.data.status in ["pending", "cancelled"];
      allow delete: if isSignedIn()
        && resource.data.userUid == request.auth.uid;
    }

    // Patient-controlled consent. Pharmacy users can read but never broaden or reactivate it.
    match /patientPharmacyConsents/{consentId} {
      allow create: if isSignedIn()
        && request.resource.data.patientUid == request.auth.uid
        && request.resource.data.active == true
        && request.resource.data.scopes is list
        && request.resource.data.scopes.hasOnly([
          "medicine_identity", "adherence_summary", "pickup_confirmation", "nms_follow_up", "service_messages"
        ])
        && request.resource.data.expiresAt is timestamp
        && request.resource.data.expiresAt > request.time;
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.patientUid == request.auth.uid)
        || isPharmacyMember(resource.data.pharmacyOrgId);
      allow update: if isSignedIn()
        && resource.data.patientUid == request.auth.uid
        && request.resource.data.patientUid == resource.data.patientUid
        && request.resource.data.pharmacyOrgId == resource.data.pharmacyOrgId
        && request.resource.data.scopes is list
        && request.resource.data.scopes.hasOnly([
          "medicine_identity", "adherence_summary", "pickup_confirmation", "nms_follow_up", "service_messages"
        ])
        && request.resource.data.expiresAt is timestamp
        && request.resource.data.expiresAt > request.time;
      allow delete: if isSignedIn() && resource.data.patientUid == request.auth.uid;
    }

    // Server-created, minimum-necessary view derived from an active patient consent.
    match /pharmacyPatientShares/{shareId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.patientUid == request.auth.uid)
        || (isPharmacyMember(resource.data.pharmacyOrgId)
          && resource.data.active == true
          && resource.data.expiresAt > request.time);
      allow write: if false;
    }

    match /prescriptionPickupEvents/{eventId} {
      allow create: if isSignedIn() && request.resource.data.patientUid == request.auth.uid;
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.patientUid == request.auth.uid)
        || isPharmacyMember(resource.data.pharmacyOrgId);
      allow update, delete: if false;
    }

    match /supportThreads/{threadId} {
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && (
          request.resource.data.pharmacyOrgId == null
          || isPharmacyMember(request.resource.data.pharmacyOrgId)
          || isAdmin()
        );
      allow read: if isAdmin() || isPharmacyMember(resource.data.pharmacyOrgId);
      allow update: if isAdmin()
        || (isPharmacyMember(resource.data.pharmacyOrgId)
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["latestMessage", "updatedAt", "status"]));
      allow delete: if isAdmin();
    }

    match /auditEvents/{eventId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
